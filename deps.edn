;; kami-genko — 原稿 (genko) manga-editor document-model SSoT (cljc) + JS bridge.
;;
;; genko-embed.ts (kami-engine-sdk の WebGPU pentab エディタ) が持っていた doc/page/node
;; モデル + node-tree ops + oplog(event-sourcing) + serialize を、純 cljc の単一ソースに
;; 切り出したもの (ADR-2607020200 / 2607020300)。tone/fukidashi は kami.mangaka.expression の
;; 語彙を共有し、`page->storyboard` で kami.mangaka.text / analyzeExpression へ橋渡しする。
;;
;; :cljs alias + shadow-cljs.edn で cljc を単一 JS(dist/kami-genko.js)にコンパイルし、
;; globalThis.KamiGenko を生やす → genko-embed.ts の inline JS が委譲する。
;; 純データ/純関数のみ (WebGPU/DOM/B2 は host)。babashka-safe / JVM・cljs・WASM 可搬。
{:paths ["src"]

 :deps {org.clojure/clojure   {:mvn/version "1.12.0"}
        org.clojure/data.json {:mvn/version "2.5.0"}   ; clj: genko JSON doc の read/write
        ;; shitsuke の kotoba.editor (portable editor kernel: selection/undo/redo/nudge/align)。
        ;; KamiGenko.editor が全ドキュメント snapshot undo/redo に使う (ADR-2607020300 段階1)。zero-dep。
        io.github.kotoba-lang/shitsuke {:git/url "https://github.com/kotoba-lang/shitsuke.git"
                                        :git/sha "d7988c24f5cb37074b6bfc1f0c2e223f4e218f84"}
        ;; canvaskit: viewport 数学の正本 (UIScrollView semantics)。genko-render の
        ;; pan/zoom/world<->screen が委譲する (ADR-2607071130。旧 freeboard 移植コピーを差し戻し)。zero-dep。
        io.github.kotoba-lang/canvaskit {:git/url "https://github.com/kotoba-lang/canvaskit.git"
                                         :git/sha "2e8ab2a996d5f405a9fd601e42993451c1f34874"}
        ;; kotobase.{client,cacao,cid} — canonical kotobase.net datom-plane client
        ;; (q/datoms/pull/transact + CACAO auth + graph CID), consumed here instead
        ;; of a vendored copy under src/kotobase/ (that vendored copy predated the
        ;; 2026-07-09 apex CACAO shape and 401'd against kotobase.net; removed —
        ;; see kotobase-client README "Why this repo exists"). cljs-only, no JVM
        ;; deps of its own; npm deps (@noble/curves v1, @noble/hashes, @ipld/dag-cbor)
        ;; come from this repo's own package.json (already present).
        io.github.kotoba-lang/kotobase-client
        {:git/url "https://github.com/kotoba-lang/kotobase-client.git"
         :git/sha "bbebe33d6888c915b64b32e5fc68720fac3aa97e"}
        ;; datascript: in-memory Datalog query engine (kami.mangaka.genko-query,
        ;; ADR-2607091900) — a LOCAL read-side query projection over genko doc/page
        ;; EDN, NOT kotobase.net's server-side {:q :transact! :db :pull :entid}
        ;; engine and NOT a new source of truth (doc EDN via read-doc/write-doc
        ;; remains canonical; see genko_query.cljc docstring). Portable cljc/cljs
        ;; lib (Maven-published, no npm counterpart needed for shadow-cljs).
        datascript/datascript {:mvn/version "1.7.8"}}

 :aliases
 {;; Browser bridge: globalThis.KamiGenko を install する単一 JS を出す (reader と同型)。
  :cljs {:extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}
                      thheller/shadow-cljs      {:mvn/version "2.28.20"}
                      reagent/reagent           {:mvn/version "1.2.0"}}}

  ;; shadow-cljs :kotobase-test(:node-test) の classpath に cljs-test/ を足すだけの
  ;; alias。cljs 専用構文(cljs.test / npm require)の kotobase-client(git dep)
  ;; smoke test を JVM の clojure -M:test(cognitect.test-runner, test/ を scan)
  ;; から隔離するため test/ とは別ディレクトリに置く。
  :cljs-test {:extra-paths ["cljs-test"]}

  ;; shadow-cljs :genko-query-test(:node-test) の classpath に test/ を足すだけの
  ;; alias (ADR-2607091900 datascript query capability, portability check).
  ;; :test alias 一式(cognitect test-runner + kami-mangaka-expression git dep,
  ;; どちらも JVM 専用/test-only)は要らないので、test/ を挟むだけの最小 alias に
  ;; 分けて kami.mangaka.genko-query-test だけを cljs (node) 上でも確認する。
  :cljs-query-test {:extra-paths ["test"]}

  :test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                       ;; bridge test が page->storyboard → analyzeExpression 連携を確認するため、
                       ;; kami.mangaka.expression を test-only の git dep で取得 (runtime 依存ではない)。
                       ;; SSoT: kotoba-lang/kami-mangaka-expression (ADR-2607102200 addendum 13;
                       ;; nested kami-engine/kami-mangaka-expression-clj is a README shim only).
                       io.github.kotoba-lang/kami-mangaka-expression
                       {:git/url "https://github.com/kotoba-lang/kami-mangaka-expression.git"
                        :sha "1fe312c6cdeb0d6aef3c20403d8748f9d4244795"}}
         :main-opts   ["-m" "cognitect.test-runner"]}

  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
