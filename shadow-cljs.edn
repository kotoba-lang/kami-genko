;; shadow-cljs build for the genko JS bridge (ADR-2607020200). Pulls cljs/shadow
;; from deps.edn :cljs alias. Release output = a single dist/kami-genko.js that,
;; on load, installs `globalThis.KamiGenko` (genko-embed.ts の inline JS が委譲する
;; model/tree/oplog/serialize/bridge API)。reader の shadow-cljs.edn と同型。
{:deps   {:aliases [:cljs]}
 :builds {:genko {:target     :browser
                  :output-dir "dist"
                  :asset-path "."
                  :modules    {:kami-genko {:init-fn kami.mangaka.genko-js/install!}}}}}
